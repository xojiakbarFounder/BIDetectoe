# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=surveillance
POSTGRES_USER=surveillance_user
POSTGRES_PASSWORD=change_me_secret

# ── YouTube stream ────────────────────────────────────────────────────────────
# Paste any public live YouTube URL or a direct RTSP / HLS endpoint
YOUTUBE_STREAM_URL=https://www.youtube.com/watch?v=LIVE_STREAM_ID
# Optional: cap frames sent to the detector (saves CPU when stream > 30 fps)
TARGET_FPS=10

# ── YOLOv8 ───────────────────────────────────────────────────────────────────
YOLO_MODEL=yolov8n.pt          # pretrained: yolov8n.pt/yolov8s.pt or custom: models/latest/best.pt
YOLO_PRETRAINED_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.40
YOLO_DEVICE=auto               # 'auto' | 'cpu' | '0' (first CUDA GPU) | 'mps'
YOLO_PERSON_CLASS_ID=0

# Fine-tuning
DATASET_YAML=dataset/dataset.yaml
TRAINING_PROJECT=experiments
TRAINING_NAME=surveillance-yolov8
TRAINED_MODELS_DIR=models
TRAIN_EPOCHS=50
TRAIN_BATCH=16
TRAIN_IMGSZ=640

# ── Virtual counting line (normalised 0-1 relative to frame dimensions) ───────
LINE_START_X=0.0
LINE_START_Y=0.5
LINE_END_X=1.0
LINE_END_Y=0.5

# ── FastAPI ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ── Gemini chatbot ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
