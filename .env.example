# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=surveillance
POSTGRES_USER=surveillance_user
POSTGRES_PASSWORD=change_me_secret

# ── YouTube stream ────────────────────────────────────────────────────────────
# Paste any public live YouTube URL or a direct RTSP / HLS endpoint
YOUTUBE_STREAM_URL=https://www.youtube.com/watch?v=LIVE_STREAM_ID
# Optional: cap frames sent to the detector (saves CPU when stream > 30 fps)
TARGET_FPS=10

# ── YOLOv8 ───────────────────────────────────────────────────────────────────
YOLO_MODEL=yolov8n.pt          # nano for speed; swap to yolov8s/m for accuracy
YOLO_CONFIDENCE=0.40
YOLO_DEVICE=cpu                # 'cpu' | '0' (first GPU) | 'mps' (Apple Silicon)

# ── Virtual counting line (normalised 0-1 relative to frame dimensions) ───────
LINE_START_X=0.0
LINE_START_Y=0.5
LINE_END_X=1.0
LINE_END_Y=0.5

# ── FastAPI ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ── OpenAI chatbot ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
